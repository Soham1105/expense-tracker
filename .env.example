# Copy to .env for local use, or set these as environment variables in Render.
# DO NOT commit the real .env file.

# --- Database (Supabase) ---
# Supabase → Project Settings → Database → Connection string (URI).
# Use the "Connection pooling" URI (port 6543) for hosted apps, and swap the
# scheme to postgresql+psycopg2. Keep sslmode=require.
# Example:
# DATABASE_URL=postgresql+psycopg2://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# --- Password gate ---
# Auth is enforced only when APP_PASSWORD is set. Leave unset for open local dev.
APP_USERNAME=admin
APP_PASSWORD=change-me-to-a-strong-password

# --- Optional connection pool tuning ---
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
